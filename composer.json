{
    "name": "capell-app/capell-packages",
    "description": "Capell 4 Packages",
    "home": "https://capell.app",
    "type": "library",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare",
            "CACHE_STORE=array php ./vendor/bin/testbench package:discover --ansi"
        ],
        "rector": "rector",
        "lint": "pint --parallel packages tests",
        "lint:changed": "zsh ../capell-4/scripts/lint-changed.sh",
        "analyze": "phpstan analyse --memory-limit=-1 --configuration=phpstan.neon",
        "prettier": "npx prettier --write \"packages/**/*.{css,js,yml,json,md,blade.php}\"",
        "eslint": "npx eslint 'packages/**/resources/js/**/*.js' --max-warnings=0",
        "preflight": [
            "@lint:changed"
        ],
        "preflight:all": [
            "@rector",
            "@lint",
            "@analyze",
            "@test"
        ],
        "coverage": "php -d memory_limit=-1 -d pcov.enabled=1 -d pcov.directory=. -d pcov.exclude='~vendor|tests|storage|bootstrap|.temp~' vendor/bin/pest --coverage --min=80 --colors=always --configuration=phpunit.xml",
        "coverage-report": "php -d memory_limit=-1 -d pcov.enabled=1 -d pcov.directory=. -d pcov.exclude='~vendor|tests|storage|bootstrap|.temp~' vendor/bin/pest --coverage --coverage-html=coverage --colors=always --configuration=phpunit.xml",
        "test:unit": "php -d memory_limit=-1 vendor/bin/pest --colors=always --parallel --configuration=phpunit.xml",
        "test": [
            "@clear",
            "@test:unit"
        ],
        "clear": [
            "CACHE_STORE=array php vendor/bin/testbench package:purge-skeleton --ansi",
            "@clear:views"
        ],
        "clear:views": "rm -rf storage/framework/views/phpunit-*",
        "prepare": "CACHE_STORE=array php vendor/bin/testbench package:discover --ansi",
        "build": "CACHE_STORE=array php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "CACHE_STORE=array php vendor/bin/testbench serve --ansi"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "./packages/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "vcs",
            "url": "https://github.com/capell-app/admin"
        },
        {
            "type": "vcs",
            "url": "https://github.com/capell-app/core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/capell-app/frontend"
        },
        {
            "type": "vcs",
            "url": "https://github.com/capell-app/installer"
        },
        {
            "type": "vcs",
            "url": "https://github.com/capell-app/marketplace"
        },
        {
            "type": "vcs",
            "url": "https://github.com/howdu/filament-adjacency-list"
        }
    ],
