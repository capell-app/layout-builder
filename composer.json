{
    "name": "capell-app/layout-builder",
    "description": "Visual layout composition, content-first editing, and public layout rendering for Capell",
    "keywords": [
        "capell",
        "layout-builder",
        "cms",
        "filament",
        "livewire"
    ],
    "homepage": "https://github.com/capell-app/layout-builder",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "capell-app/admin": "^4.0 || 4.x-dev",
        "capell-app/content-blocks": "^4.0 || 4.x-dev",
        "capell-app/core": "^4.0 || 4.x-dev",
        "capell-app/frontend": "^4.0 || 4.x-dev"
    },
    "autoload": {
        "psr-4": {
            "Capell\\LayoutBuilder\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\LayoutBuilder\\LayoutBuilderServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "type": "library",
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "support": {
        "source": "https://github.com/capell-app/capell-packages",
        "docs": "https://docs.capell.app/packages/layout-builder"
    }
}
