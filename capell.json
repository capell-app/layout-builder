                "Capell\\LayoutBuilder\\Models\\Widget",
                "Capell\\LayoutBuilder\\Models\\WidgetAsset",
                "Capell\\LayoutBuilder\\Models\\WidgetWidget",
                "Capell\\LayoutBuilder\\Models\\LayoutPreset",
