    "security": {
        "riskTier": "standard",
        "publicSurface": {
            "routeNames": [
                "capell-layout-builder.fragments.show",
                "capell-layout-builder.layout-widgets.show"
            ],
            "auth": "public",
            "csrfExemptRoutes": [],
            "signedRoutes": [],
            "tokenizedRoutes": [],
            "webhookRoutes": [],
            "throttledRoutes": []
