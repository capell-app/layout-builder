            "class": "Capell\\LayoutBuilder\\Manifest\\LayoutBuilderPageTypesContribution",
            "pageTypes": [
                {
                    "name": "widget",
                    "modelClass": "Capell\\LayoutBuilder\\Models\\Widget"
                }
            ]
        },
        {
            "type": "route",
            "class": "Capell\\LayoutBuilder\\Manifest\\LayoutBuilderRoutesContribution",
            "routes": [
                "capell-layout-builder.fragments.show",
                "capell-layout-builder.layout-widgets.show"
            ],
            "prefix": "_fragments",
            "middleware": ["web"],
            "reservedFrontendPath": "_fragments"
        },
        {
            "type": "migration",
            "class": "Capell\\LayoutBuilder\\Manifest\\LayoutBuilderMigrationsContribution",
            "migrationFiles": [
