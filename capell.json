                "ViewAny:Layout",
                "View:Layout",
                "Create:Layout",
                "EditContent:Layout",
                "EditLayout:Layout",
                "Update:Layout",
                "Delete:Layout",
                "DeleteAny:Layout",
                "Restore:Layout",
                "ForceDelete:Layout",
                "Replicate:Layout",
                "Reorder:Layout",
                "BulkMutate:Layout"
            ]
        }
