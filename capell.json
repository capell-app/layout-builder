{
    "manifest-version": 3,
    "name": "capell-app/layout-builder",
    "slug": "layout-builder",
    "displayName": "Layout Builder",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Compose pages visually with reusable widgets and named layout areas — edit content fast in content-first mode, or drag-and-drop the full layout. Renders to clean, query-free public HTML that never leaks editor internals.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\LayoutBuilder",
    "surfaces": ["admin", "frontend", "console"],
    "dependencies": {
        "requires": [
            "capell-app/core",
            "capell-app/admin",
            "capell-app/block-library",
            "capell-app/frontend"
        ],
        "supports": [
            "capell-app/content-sections",
            "capell-app/frontend-authoring",
            "capell-app/publishing-studio",
            "capell-app/structured-content-library"
        ],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": ["Capell\\LayoutBuilder\\LayoutBuilderServiceProvider"],
        "runtime": ["Capell\\LayoutBuilder\\LayoutBuilderServiceProvider"],
        "admin": ["Capell\\LayoutBuilder\\LayoutBuilderServiceProvider"],
        "frontend": ["Capell\\LayoutBuilder\\LayoutBuilderServiceProvider"]
    },
    "contributes": [
        {
            "type": "admin-resource",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "resourceClass": "Capell\\LayoutBuilder\\Filament\\Resources\\Layouts\\LayoutResource",
            "group": "Layout"
        },
        {
            "type": "admin-resource",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "resourceClass": "Capell\\LayoutBuilder\\Filament\\Resources\\Widgets\\WidgetResource",
            "group": "Widget"
        },
        {
            "type": "configurator",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "configuratorEnum": "Capell\\LayoutBuilder\\Enums\\ConfiguratorTypeEnum",
            "groups": [
                "LayoutContainers",
                "LayoutWidgets",
                "Widgets",
                "WidgetAssets"
            ]
        },
        {
            "type": "schema-extender",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "extenderClass": "Capell\\LayoutBuilder\\Filament\\Resources\\Pages\\Schemas\\Extenders\\PageSchemaExtender",
            "tag": "Page"
        },
        {
            "type": "schema-extender",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "extenderClass": "Capell\\LayoutBuilder\\Filament\\Extenders\\Page\\HeroPageSchemaExtender",
            "tag": "Page"
        },
        {
            "type": "schema-extender",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "extenderClass": "Capell\\LayoutBuilder\\Filament\\Resources\\Layouts\\Schemas\\Extenders\\LayoutSchemaExtender",
            "tag": "Layout"
        },
        {
            "type": "asset",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "package": "capell-layout-builder",
            "surface": "admin"
        }
    ],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": [
            "layouts",
            "widgets",
            "widget_assets",
            "widget_widgets",
            "layout_presets",
            "layout_bulk_change_runs",
            "layout_bulk_change_results"
        ]
    },
    "commands": {
        "install": "capell:layout-builder-install",
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "actions": {
        "install": "Capell\\LayoutBuilder\\Actions\\InstallLayoutBuilderPackageAction",
        "setup": "Capell\\LayoutBuilder\\Actions\\SetupLayoutBuilderPackageAction"
    },
    "settings": [],
    "permissions": [
        "ViewAny:Layout",
        "View:Layout",
        "Create:Layout",
        "EditContent:Layout",
        "EditLayout:Layout",
        "Update:Layout",
        "Delete:Layout",
        "DeleteAny:Layout",
        "Restore:Layout",
        "ForceDelete:Layout",
        "Replicate:Layout",
        "Reorder:Layout",
        "BulkMutate:Layout"
    ],
    "capabilities": [
        "layout-builder",
        "layout-builder-admin",
        "layout-builder-content-first",
        "layout-builder-public-rendering"
    ],
    "security": {
        "riskTier": "standard",
        "publicSurface": {
            "routeNames": [],
            "auth": "none",
            "csrfExemptRoutes": [],
            "signedRoutes": [],
            "tokenizedRoutes": [],
            "webhookRoutes": [],
            "throttledRoutes": []
        },
        "sensitiveData": {
            "encryptedFields": [],
            "hashedTokenFields": [
                "layout_bulk_change_runs.original_container_hash",
                "layout_bulk_change_runs.proposed_container_hash"
            ],
            "redactedOutputClasses": [
                "Capell\\LayoutBuilder\\Actions\\SaveLayoutPresetAction"
            ],
            "plaintextJustifications": []
        },
        "publicOutput": {
            "cacheSafe": true,
            "forbidAuthoringSurface": true,
            "forbidSecrets": true,
            "forbidPublicBladeQueries": true
        },
        "externalHttpClients": {
            "requiresTimeouts": false,
            "requiresSecretRedaction": false,
            "clients": []
        },
        "adminSurface": {
            "authorization": "permissions",
            "permissions": [
                "ViewAny:Layout",
                "View:Layout",
                "Create:Layout",
                "EditContent:Layout",
                "EditLayout:Layout",
                "Update:Layout",
                "Delete:Layout",
                "DeleteAny:Layout",
                "Restore:Layout",
                "ForceDelete:Layout",
                "Replicate:Layout",
                "Reorder:Layout",
                "BulkMutate:Layout"
            ]
        }
    },
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 50,
        "cacheTags": ["layout-builder"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale", "page"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "layout-builder.package-health",
            "label": "Layout Builder package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\LayoutBuilder\\Health\\LayoutBuilderHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "Compose pages visually with reusable widgets and named layout areas — edit content fast in content-first mode, or drag-and-drop the full layout. Renders to clean, query-free public HTML that never leaks editor internals.",
        "screenshots": [
            {
                "path": "docs/assets/marketplace/extension-card.jpg",
                "alt": "Layout Builder extension preview image",
                "caption": "Layout Builder extension preview"
            },
            {
                "path": "docs/assets/marketplace/bulk-change-criteria.svg",
                "alt": "Layout Builder bulk change criteria wizard",
                "caption": "Admins define filters and guided widget operations before any shared layout is mutated."
            },
            {
                "path": "docs/assets/marketplace/bulk-change-review.svg",
                "alt": "Layout Builder bulk change review table",
                "caption": "Review affected layouts, page counts, widget order diffs, warnings, and skipped records before approval."
            },
            {
                "path": "docs/assets/marketplace/bulk-change-approved.svg",
                "alt": "Layout Builder approved bulk change run",
                "caption": "Hash-guarded apply skips layouts that changed after preview instead of overwriting newer editor work."
            },
            {
                "path": "docs/assets/marketplace/content-first-editor.svg",
                "alt": "Layout Builder content-first page editor",
                "caption": "Editors update assigned widget assets without opening the full layout canvas."
            },
            {
                "path": "docs/assets/marketplace/layout-areas.svg",
                "alt": "Layout Builder named layout areas",
                "caption": "Header, main, sidebar, and footer placement stay explicit across themes."
            },
            {
                "path": "docs/assets/marketplace/public-render-output.svg",
                "alt": "Layout Builder public render output",
                "caption": "Resolved widgets render as clean visitor HTML without exposing editor metadata."
            }
        ],
        "categories": ["admin", "foundation", "frontend"]
    },
    "contributionTraceability": {
        "deferredContributions": ["migration", "model", "page-type", "route"]
    }
}
