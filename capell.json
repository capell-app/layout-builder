{
    "manifest-version": 3,
    "name": "capell-app/layout-builder",
    "slug": "layout-builder",
    "displayName": "Layout Builder",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Compose pages visually with reusable widgets and named layout areas — edit content fast in content-first mode, or drag-and-drop the full layout. Renders to clean, query-free public HTML that never leaks editor internals.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\LayoutBuilder",
    "surfaces": ["admin", "frontend", "console"],
    "dependencies": {
        "requires": [
            "capell-app/core",
            "capell-app/admin",
            "capell-app/block-library",
            "capell-app/frontend"
        ],
        "supports": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": ["Capell\\LayoutBuilder\\LayoutBuilderServiceProvider"],
        "runtime": ["Capell\\LayoutBuilder\\LayoutBuilderServiceProvider"],
        "admin": ["Capell\\LayoutBuilder\\LayoutBuilderServiceProvider"],
        "frontend": ["Capell\\LayoutBuilder\\LayoutBuilderServiceProvider"]
    },
    "contributes": [
        {
            "type": "admin-resource",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "resourceClass": "Capell\\LayoutBuilder\\Filament\\Resources\\Layouts\\LayoutResource",
            "group": "Layout"
        },
        {
            "type": "admin-resource",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "resourceClass": "Capell\\LayoutBuilder\\Filament\\Resources\\Widgets\\WidgetResource",
            "group": "Widget"
        },
        {
            "type": "configurator",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "configuratorEnum": "Capell\\LayoutBuilder\\Enums\\ConfiguratorTypeEnum",
            "groups": [
                "LayoutContainers",
                "LayoutWidgets",
                "Widgets",
                "WidgetAssets"
            ]
        },
        {
            "type": "schema-extender",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "extenderClass": "Capell\\LayoutBuilder\\Filament\\Resources\\Pages\\Schemas\\Extenders\\PageSchemaExtender",
            "tag": "Page"
        },
        {
            "type": "schema-extender",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "extenderClass": "Capell\\LayoutBuilder\\Filament\\Extenders\\Page\\HeroPageSchemaExtender",
            "tag": "Page"
        },
        {
            "type": "schema-extender",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "extenderClass": "Capell\\LayoutBuilder\\Filament\\Resources\\Layouts\\Schemas\\Extenders\\LayoutSchemaExtender",
            "tag": "Layout"
        },
        {
            "type": "asset",
            "class": "Capell\\LayoutBuilder\\Support\\LayoutBuilderAdminRegistrar",
            "package": "capell-layout-builder",
            "surface": "admin"
        }
    ],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": [
            "layouts",
            "widgets",
            "widget_assets",
            "widget_widgets"
        ]
    },
    "commands": {
        "install": "capell:layout-builder-install",
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "actions": {
        "install": "Capell\\LayoutBuilder\\Actions\\InstallLayoutBuilderPackageAction"
    },
    "settings": [],
    "permissions": [
        "ViewAny:Layout",
        "View:Layout",
        "Create:Layout",
        "EditContent:Layout",
        "EditLayout:Layout",
        "Update:Layout",
        "Delete:Layout",
        "DeleteAny:Layout",
        "Restore:Layout",
        "ForceDelete:Layout",
        "Replicate:Layout",
        "Reorder:Layout",
        "BulkMutate:Layout"
    ],
    "capabilities": [
        "layout-builder",
        "layout-builder-admin",
        "layout-builder-content-first",
        "layout-builder-public-rendering"
    ],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 50,
        "cacheTags": ["layout-builder"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale", "page"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "layout-builder.package-health",
            "label": "Layout Builder package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\LayoutBuilder\\Health\\LayoutBuilderHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "Compose pages visually with reusable widgets and named layout areas — edit content fast in content-first mode, or drag-and-drop the full layout. Renders to clean, query-free public HTML that never leaks editor internals.",
        "screenshots": [
            {
                "path": "docs/assets/marketplace/extension-card.jpg",
                "alt": "Layout Builder extension preview image",
                "caption": "Layout Builder extension preview"
            },
            {
                "path": "docs/screenshots/widgets-admin-index.png",
                "alt": "Layout Builder widgets admin index in Capell",
                "caption": "Review reusable widgets, filters, usage columns, and widget actions in the Capell admin."
            },
            {
                "path": "docs/screenshots/widgets-admin-index-dark.png",
                "alt": "Layout Builder widgets admin index in dark mode",
                "caption": "Dark-mode widget management keeps reusable layout blocks visible in the admin chrome."
            },
            {
                "path": "docs/screenshots/create-edit-widget-form.png",
                "alt": "Layout Builder create widget form in Capell",
                "caption": "Configure widget details, placement, items, appearance, background, rendering, and admin metadata."
            },
            {
                "path": "docs/screenshots/create-edit-widget-form-dark.png",
                "alt": "Layout Builder create widget form in dark mode",
                "caption": "Create and edit reusable widgets with the same controls available in dark mode."
            },
            {
                "path": "docs/screenshots/sections-admin-index.png",
                "alt": "Layout Builder layouts admin index in Capell",
                "caption": "Manage reusable layouts that connect page records to frontend rendering."
            },
            {
                "path": "docs/screenshots/sections-admin-index-dark.png",
                "alt": "Layout Builder layouts admin index in dark mode",
                "caption": "Manage layout records from the dark Capell admin interface."
            }
        ],
        "categories": ["admin", "foundation", "frontend"]
    },
    "contributionTraceability": {
        "deferredContributions": ["migration", "model", "page-type", "route"]
    }
}
