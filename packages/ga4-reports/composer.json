{
    "name": "capell-app/ga4-reports",
    "description": "GA4 Reports 4 dashboard reporting for Capell.",
    "keywords": [
        "capell",
        "ga4-reports",
        "ga4",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/ga4-reports",
    "license": "proprietary",
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "capell-app/admin": "^4.0",
        "capell-app/core": "^4.0",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-data": "^4.5",
        "spatie/laravel-package-tools": "^1.14.1"
    },
    "autoload": {
        "psr-4": {
            "Capell\\GA4Reports\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\GA4Reports\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\GA4Reports\\Providers\\GA4ReportsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "pest"
    },
    "prefer-stable": true
}
