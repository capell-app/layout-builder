{
    "manifest-version": 3,
    "name": "capell-app/email-studio",
    "slug": "email-studio",
    "displayName": "Email Studio",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Email Studio gives Capell a transactional email centre for reusable templates, delivery profiles, send audit trails, suppressions, replies, and provider events.",
    "product": {
        "group": "Capell Communications",
        "tier": "premium",
        "bundle": "communications"
    },
    "namespace": "Capell\\EmailStudio",
    "surfaces": [
        "admin",
        "frontend",
        "console"
    ],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/frontend"
        ],
        "optional": [
            "capell-app/campaign-studio",
            "capell-app/form-builder",
            "capell-app/insights"
        ],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\EmailStudio\\Providers\\EmailStudioServiceProvider"
        ],
        "admin": [
            "Capell\\EmailStudio\\Providers\\AdminServiceProvider"
        ],
        "frontend": [
            "Capell\\EmailStudio\\Providers\\FrontendServiceProvider"
        ]
    },
    "contributes": [],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [
        "delivery-audit",
        "provider-adapters",
        "suppressions",
        "template-rendering",
        "transactional-email"
    ],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": [
            "email-studio"
        ],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": [
                "site",
                "locale"
            ],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "Email Studio gives Capell a transactional email centre for reusable templates, delivery profiles, send audit trails, suppressions, replies, and provider events.",
        "screenshots": [],
        "categories": [
            "admin",
            "communications",
            "console",
            "frontend"
        ]
    },
    "contributionTraceability": {
        "deferredContributions": [
            "model"
        ]
    }
}
