{
    "manifest-version": 3,
    "name": "capell-app/hero",
    "slug": "hero",
    "displayName": "Hero",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Hero provides the default Capell home hero widget, rendering, and layout setup.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\Hero",
    "surfaces": ["frontend", "console"],
    "dependencies": {
        "requires": ["capell-app/core", "capell-app/frontend"],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": ["Capell\\Hero\\Providers\\HeroServiceProvider"],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": "capell:hero-setup",
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 0,
        "cacheTags": ["hero"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "hero.package-health",
            "label": "Hero package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\Hero\\Health\\HeroHealthCheck",
            "severity": "critical",
            "surface": "frontend"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "Hero provides the default Capell home hero widget, rendering, and layout setup.",
        "screenshots": [],
        "categories": ["console", "foundation", "frontend"]
    }
}
