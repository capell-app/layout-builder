{
    "manifest-version": 3,
    "name": "capell-app/media-ai",
    "slug": "media-ai",
    "displayName": "Media AI",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Media AI adds optional AI-assisted media actions for Capell.",
    "product": {
        "group": "Capell Media",
        "tier": "premium",
        "bundle": "media"
    },
    "namespace": "Capell\\MediaAI",
    "surfaces": ["admin", "console"],
    "dependencies": {
        "requires": ["capell-app/admin", "capell-app/core"],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": ["Capell\\MediaAI\\Providers\\MediaAIServiceProvider"],
        "runtime": [],
        "admin": ["Capell\\MediaAI\\Providers\\MediaAIServiceProvider"],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": ["media-ai", "media-ai-admin", "media-ai-console"],
    "performance": {
        "frontendRenderBudgetMs": 0,
        "adminQueryBudget": 40,
        "cacheTags": [],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": [],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": false
        }
    },
    "healthChecks": [
        {
            "key": "media-ai.provider-adapter",
            "label": "Image doctor provider adapter is resolved through the Media AI contract.",
            "class": "Capell\\MediaAI\\Health\\MediaAIHealthCheck",
            "severity": "critical",
            "surface": "admin"
        },
        {
            "key": "media-ai.edit-action",
            "label": "AI media edit action remains hidden until a real image doctor is bound.",
            "class": "Capell\\MediaAI\\Health\\MediaAIHealthCheck",
            "severity": "critical",
            "surface": "admin"
        },
        {
            "key": "media-ai.structured-request",
            "label": "Media AI sends structured operation and instruction data to provider adapters.",
            "class": "Capell\\MediaAI\\Health\\MediaAIHealthCheck",
            "severity": "warning",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "Media AI adds optional AI-assisted media actions for Capell.",
        "screenshots": [],
        "categories": ["admin", "console", "media"]
    }
}
