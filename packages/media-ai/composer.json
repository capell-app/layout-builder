{
    "name": "capell-app/media-ai",
    "description": "Optional AI-assisted media actions for Capell.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/core": "*",
        "filament/filament": "^4.7|^5.2",
        "laravel/framework": "^11.44.2|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.14.1"
    },
    "suggest": {
        "capell-app/ai-orchestrator": "Bind Capell\\MediaAI\\Contracts\\ImageDoctor to an AIOrchestrator-backed implementation."
    },
    "autoload": {
        "psr-4": {
            "Capell\\MediaAI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\MediaAI\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\MediaAI\\Providers\\MediaAIServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
