{
    "name": "capell-app/workspaces",
    "description": "Workspace drafting system for Capell",
    "keywords": [
        "capell",
        "workspaces",
        "laravel",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/workspaces",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "capell-app/core": "*",
        "capell-app/admin": "*",
        "capell-app/navigation": "*",
        "jfcherng/php-diff": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Workspaces\\": "src/",
            "Capell\\Workspaces\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Workspaces\\Providers\\WorkspacesServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
