{
    "manifest-version": 3,
    "name": "capell-app/content-blocks",
    "slug": "content-blocks",
    "displayName": "Content Blocks",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Content Blocks provides shared typed block definitions and registration contracts for Capell content packages.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\ContentBlocks",
    "surfaces": ["shared"],
    "dependencies": {
        "requires": ["capell-app/core"],
        "optional": [
            "capell-app/content-sections",
            "capell-app/foundation-theme"
        ],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\ContentBlocks\\Providers\\ContentBlocksServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [],
    "performance": {
        "frontendRenderBudgetMs": 0,
        "adminQueryBudget": 0,
        "cacheTags": ["content-blocks"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": [],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": false
        }
    },
    "healthChecks": [
        {
            "key": "content-blocks.package-health",
            "label": "Content Blocks package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\ContentBlocks\\Health\\ContentBlocksHealthCheck",
            "severity": "critical",
            "surface": "shared"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "Shared typed content block primitives and registration contracts for Capell packages.",
        "screenshots": [],
        "categories": ["foundation", "shared"]
    }
}
