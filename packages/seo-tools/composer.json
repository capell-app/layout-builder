{
    "name": "capell-app/seo-tools",
    "description": "SEO tools for Capell (sitemaps, structured data, social meta, AI assistant)",
    "keywords": [
        "capell",
        "seo",
        "sitemap",
        "structured-data",
        "assistant",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/frontend": "*",
        "prism-php/prism": "^0.100"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\SeoTools\\": "src/",
            "Capell\\SeoTools\\Assistant\\Database\\Factories\\": "src/Assistant/database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\SeoTools\\Providers\\SeoToolsServiceProvider",
                "Capell\\SeoTools\\Assistant\\Providers\\AssistantServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
