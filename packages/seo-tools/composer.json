{
    "name": "capell-app/seo-tools",
    "description": "SEO tools for Capell (sitemaps, structured data, social meta, AI assistant)",
    "keywords": [
        "capell",
        "seo",
        "sitemap",
        "structured-data",
        "assistant",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/analytics": "*",
        "capell-app/frontend": "*",
        "icamys/php-sitemap-generator": "^4.4",
        "prism-php/prism": "^0.100"
    },
    "suggest": {
        "capell-app/redirects": "Enables redirect creation from broken link reports.",
        "capell-app/workspaces": "Enables workspace-aware SEO publish reports."
    },
    "require-dev": {
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\SeoTools\\": "src/",
            "Capell\\SeoTools\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\SeoTools\\Providers\\SeoToolsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
