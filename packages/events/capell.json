{
    "name": "capell-app/events",
    "capell-version": "^4.0",
    "title": "Events",
    "description": "Events adds listings, recurring events, venues, RSVPs, calendar feeds, and Event schema.",
    "kind": "plugin",
    "contexts": ["admin", "frontend", "console"],
    "requires": [
        "capell-app/admin",
        "capell-app/frontend",
        "capell-app/layout-builder",
        "capell-app/navigation",
        "capell-app/publishing-studio"
    ],
    "optional": [
        "capell-app/address",
        "capell-app/form-builder",
        "capell-app/seo-suite",
        "capell-app/tags"
    ],
    "providers": {
        "shared": ["Capell\\Events\\Providers\\EventsServiceProvider"]
    },
    "commands": {
        "install": "capell:events-install"
    }
}
