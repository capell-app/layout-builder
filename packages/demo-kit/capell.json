{
    "manifest-version": 3,
    "name": "capell-app/demo-kit",
    "slug": "demo-kit",
    "displayName": "Demo Kit",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Demo Kit provides example content and media for local Capell demos.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\DemoKit",
    "surfaces": ["admin", "frontend"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/frontend",
            "capell-app/content-sections",
            "capell-app/navigation"
        ],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": ["Capell\\DemoKit\\Providers\\DemoKitServiceProvider"],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": "capell:demo-kit-doctor"
    },
    "settings": [],
    "permissions": [],
    "capabilities": [],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": ["demo-kit"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "demo-kit.package-health",
            "label": "Demo Kit package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\DemoKit\\Health\\DemoKitHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "Demo Kit provides example content and media for local Capell demos.",
        "screenshots": [],
        "categories": ["admin", "foundation", "frontend"]
    },
    "contributionTraceability": {
        "deferredContributions": ["admin-page"]
    }
}
