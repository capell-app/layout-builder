{
    "manifest-version": 3,
    "name": "capell-app/form-builder",
    "slug": "form-builder",
    "displayName": "Form Builder",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "FormBuilder adds form definitions, encrypted submissions, frontend Livewire rendering, validation, and submission status handling to Capell.",
    "product": {
        "group": "Capell FormBuilder",
        "tier": "premium",
        "bundle": "form-builder"
    },
    "namespace": "Capell\\FormBuilder",
    "surfaces": ["admin", "frontend"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/frontend"
        ],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\FormBuilder\\Providers\\FormBuilderServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [
        "form-builder",
        "form-builder-admin",
        "form-builder-frontend"
    ],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": ["form-builder"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "form-builder.validation",
            "label": "Public submissions are validated from typed field schema",
            "class": "Capell\\FormBuilder\\Health\\FormBuilderHealthCheck",
            "severity": "critical",
            "surface": "frontend"
        },
        {
            "key": "form-builder.spam-honeypot",
            "label": "Triggered honeypot submissions are recorded as spam without dispatching workflows",
            "class": "Capell\\FormBuilder\\Health\\FormBuilderHealthCheck",
            "severity": "critical",
            "surface": "frontend"
        },
        {
            "key": "form-builder.encrypted-submissions",
            "label": "Submission payload and metadata remain encrypted at rest",
            "class": "Capell\\FormBuilder\\Health\\FormBuilderHealthCheck",
            "severity": "warning",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "FormBuilder adds form definitions, encrypted submissions, frontend Livewire rendering, validation, and submission status handling to Capell.",
        "screenshots": [],
        "categories": ["admin", "form-builder", "frontend"]
    },
    "contributionTraceability": {
        "deferredContributions": ["admin-resource", "model"]
    }
}
