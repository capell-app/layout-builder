{
    "manifest-version": 3,
    "name": "capell-app/diagnostics",
    "slug": "diagnostics",
    "displayName": "Diagnostics",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Diagnostics adds operational diagnostics for cache, configuration drift, migrations, packages, registries, queues, permissions, setup health, and Tailwind build status.",
    "product": {
        "group": "Capell Operations",
        "tier": "premium",
        "bundle": "operations"
    },
    "namespace": "Capell\\Diagnostics",
    "surfaces": ["admin", "console"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/html-cache"
        ],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\Diagnostics\\Providers\\DiagnosticsServiceProvider"
        ],
        "admin": ["Capell\\Diagnostics\\Providers\\AdminServiceProvider"],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [
        "accessDiagnostics",
        "viewDiagnostics",
        "View:PermissionAuditPage",
        "View:CommandPalettePage",
        "View:QueueHealthPage"
    ],
    "capabilities": ["diagnostics", "diagnostics-admin", "diagnostics-console"],
    "performance": {
        "frontendRenderBudgetMs": 0,
        "adminQueryBudget": 40,
        "cacheTags": [],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": [],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": false
        }
    },
    "healthChecks": [
        {
            "key": "diagnostics.package-catalog",
            "label": "Installed Capell packages are discovered from composer metadata",
            "class": "Capell\\Diagnostics\\Health\\DiagnosticsHealthCheck",
            "severity": "critical",
            "surface": "admin"
        },
        {
            "key": "diagnostics.manifest-health",
            "label": "Package manifests expose bundle, command, and health-check metadata",
            "class": "Capell\\Diagnostics\\Health\\DiagnosticsHealthCheck",
            "severity": "warning",
            "surface": "admin"
        },
        {
            "key": "diagnostics.system-health-widgets",
            "label": "System health widgets are registered for developer users",
            "class": "Capell\\Diagnostics\\Health\\DiagnosticsHealthCheck",
            "severity": "critical",
            "surface": "admin"
        },
        {
            "key": "diagnostics.queue-health",
            "label": "Queue health page and failed-job summary are available",
            "class": "Capell\\Diagnostics\\Health\\DiagnosticsHealthCheck",
            "severity": "warning",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "Diagnostics adds operational diagnostics for cache, configuration drift, migrations, packages, registries, queues, permissions, setup health, and Tailwind build status.",
        "screenshots": [],
        "categories": ["admin", "console", "operations"]
    },
    "contributionTraceability": {
        "deferredContributions": [
            "admin-page",
            "dashboard-widget",
            "page-type",
            "route"
        ]
    }
}
