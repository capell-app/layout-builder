{
    "name": "capell-app/theme-studio-admin",
    "description": "Dedicated Filament admin experience for Capell Theme Studio",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/core": "*",
        "capell-app/theme-studio-core": "*",
        "filament/filament": "^4.7|^5.2",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-package-tools": "^1.14"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^3.0|^4.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\ThemeStudio\\Admin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\ThemeStudio\\Admin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\ThemeStudio\\Admin\\ThemeStudioAdminServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    }
}
