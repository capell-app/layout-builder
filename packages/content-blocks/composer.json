{
    "name": "capell-app/content-blocks",
    "description": "Reusable content blocks for Capell",
    "keywords": [
        "capell",
        "content-blocks",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/content-blocks",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/core": "*",
        "capell-app/frontend": "*"
    },
    "suggest": {
        "capell-app/mosaic": "Enables Mosaic widget integration for reusable content blocks.",
        "capell-app/workspaces": "Enables workspace-aware content block publishing integration."
    },
    "autoload": {
        "psr-4": {
            "Capell\\ContentBlocks\\": "src/",
            "Capell\\ContentBlocks\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\ContentBlocks\\Providers\\ContentBlocksServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
