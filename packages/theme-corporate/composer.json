{
    "name": "capell-app/theme-corporate",
    "description": "Trust-led corporate theme for Capell",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "capell-app/core": "*",
        "capell-app/foundation-theme": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0|^4.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\ThemeStudio\\Corporate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\ThemeStudio\\Corporate\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\ThemeStudio\\Corporate\\CorporateThemeServiceProvider"
            ]
        }
    }
}
