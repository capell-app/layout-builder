{
    "name": "capell-app/campaign-studio",
    "description": "Campaign landing pages, CTA blocks, UTM attribution, conversion goals, and campaign insights.",
    "keywords": [
        "capell",
        "campaign-studio",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "homepage": "https://github.com/capell-app/campaign-studio",
    "license": "proprietary",
    "authors": [
        {
            "name": "Capell Team",
            "email": "team@capell.app",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "capell-app/admin": "^4.0",
        "capell-app/insights": "^4.0",
        "capell-app/core": "^4.0",
        "capell-app/form-builder": "^4.0",
        "capell-app/frontend": "^4.0",
        "capell-app/layout-builder": "^4.0",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-data": "^4.5",
        "spatie/laravel-package-tools": "^1.14.1"
    },
    "autoload": {
        "psr-4": {
            "Capell\\CampaignStudio\\": "src/",
            "Capell\\CampaignStudio\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\CampaignStudio\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\CampaignStudio\\Providers\\CampaignStudioServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "pest"
    },
    "prefer-stable": true
}
