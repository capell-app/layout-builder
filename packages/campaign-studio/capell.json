{
    "manifest-version": 3,
    "name": "capell-app/campaign-studio",
    "slug": "campaign-studio",
    "displayName": "Campaign Studio",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "CampaignStudio adds campaign groups, landing pages, CTA blocks, conversion goals, UTM attribution, and conversion reporting to Capell.",
    "product": {
        "group": "Capell Growth",
        "tier": "premium",
        "bundle": "growth"
    },
    "namespace": "Capell\\CampaignStudio",
    "surfaces": ["admin", "frontend"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/form-builder",
            "capell-app/frontend",
            "capell-app/insights"
        ],
        "optional": ["capell-app/seo-suite"],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\CampaignStudio\\Providers\\CampaignStudioServiceProvider"
        ],
        "admin": ["Capell\\CampaignStudio\\Providers\\AdminServiceProvider"],
        "frontend": [
            "Capell\\CampaignStudio\\Providers\\FrontendServiceProvider"
        ]
    },
    "contributes": [],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [
        "campaign-studio",
        "campaign-studio-admin",
        "campaign-studio-frontend"
    ],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": ["campaign-studio"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "campaign-studio.package-health",
            "label": "Campaign Studio package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\CampaignStudio\\Health\\CampaignStudioHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "CampaignStudio adds campaign groups, landing pages, CTA blocks, conversion goals, UTM attribution, and conversion reporting to Capell.",
        "screenshots": [],
        "categories": ["admin", "frontend", "growth"]
    },
    "contributionTraceability": {
        "deferredContributions": [
            "admin-resource",
            "configurator",
            "dashboard-widget",
            "model",
            "overview-stat"
        ]
    }
}
