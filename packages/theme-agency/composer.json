{
    "name": "capell-app/theme-agency",
    "description": "Expressive agency renderer for Capell Theme Studio",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "capell-app/core": "*",
        "capell-app/default-theme": "*",
        "capell-app/theme-studio-core": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0|^4.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\ThemeStudio\\Agency\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\ThemeStudio\\Agency\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\ThemeStudio\\Agency\\AgencyThemeServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    }
}
