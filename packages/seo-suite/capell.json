{
    "manifest-version": 2,
    "name": "capell-app/seo-suite",
    "kind": "package",
    "capell-version": "^4.0",
    "productGroup": "Capell Search & SEO",
    "tier": "premium",
    "bundle": "search-seo",
    "description": "SEO Suite adds metadata panels, structured data, broken link tracking, Search Console insights, AI-assisted content briefs, and publish checks.",
    "surfaces": ["admin", "frontend", "console"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/insights",
            "capell-app/frontend",
            "capell-app/site-discovery"
        ],
        "optional": [],
        "conflicts": []
    },
    "lifecycle": {
        "activation": "manual",
        "defaultStatus": "available",
        "requiresInstallCommand": false
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": ["Capell\\SeoSuite\\Providers\\SeoSuiteServiceProvider"],
        "admin": [],
        "frontend": []
    },
    "database": {
        "migrations": true,
        "settings": true,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "setupParams": [],
        "demo": null,
        "demoParams": [],
        "health": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [],
    "assets": [],
    "healthChecks": []
}
