{
    "manifest-version": 3,
    "name": "capell-app/seo-suite",
    "slug": "seo-suite",
    "displayName": "SEO Suite",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "SEO Suite adds metadata panels, structured data, broken link tracking, Search Console insights, AI-assisted content briefs, and publish checks.",
    "product": {
        "group": "Capell Search & SEO",
        "tier": "premium",
        "bundle": "search-seo"
    },
    "namespace": "Capell\\SeoSuite",
    "surfaces": ["admin", "frontend", "console"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/frontend",
            "capell-app/insights",
            "capell-app/site-discovery"
        ],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": ["Capell\\SeoSuite\\Providers\\SeoSuiteServiceProvider"],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": true,
        "settings": true,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [
        "seo-suite",
        "seo-suite-admin",
        "seo-suite-console",
        "seo-suite-frontend"
    ],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": ["seo-suite"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "seo-suite.page-report",
            "label": "Page SEO reports cover metadata, canonical, robots, schema, redirects, and Search Console signals.",
            "class": "Capell\\SeoSuite\\Health\\SeoSuiteHealthCheck",
            "severity": "critical",
            "surface": "admin"
        },
        {
            "key": "seo-suite.schema-graph",
            "label": "Structured data templates build schema.org graph output.",
            "class": "Capell\\SeoSuite\\Health\\SeoSuiteHealthCheck",
            "severity": "warning",
            "surface": "frontend"
        },
        {
            "key": "seo-suite.broken-links",
            "label": "Broken link records produce redirect opportunities.",
            "class": "Capell\\SeoSuite\\Health\\SeoSuiteHealthCheck",
            "severity": "warning",
            "surface": "admin"
        },
        {
            "key": "seo-suite.ai-discovery",
            "label": "AI discovery outputs llms.txt and markdown page surfaces.",
            "class": "Capell\\SeoSuite\\Health\\SeoSuiteHealthCheck",
            "severity": "warning",
            "surface": "frontend"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "SEO Suite adds metadata panels, structured data, broken link tracking, Search Console insights, AI-assisted content briefs, and publish checks.",
        "screenshots": [],
        "categories": ["admin", "console", "frontend", "search-seo"]
    },
    "contributionTraceability": {
        "deferredContributions": ["admin-page", "model", "route"]
    }
}
