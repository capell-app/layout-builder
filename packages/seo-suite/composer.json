{
    "name": "capell-app/seo-suite",
    "description": "SEO tools for Capell (sitemaps, structured data, social meta, AI ai-orchestrator)",
    "keywords": [
        "capell",
        "seo",
        "sitemap",
        "structured-data",
        "ai-orchestrator",
        "laravel",
        "filamentphp",
        "cms"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/insights": "*",
        "capell-app/frontend": "*",
        "icamys/php-sitemap-generator": "^4.4",
        "prism-php/prism": "^0.100"
    },
    "suggest": {
        "capell-app/redirects": "Enables redirect creation from broken link dashboard-dashboard_reports.",
        "capell-app/publishing-studio": "Enables workspace-aware SEO publish dashboard-dashboard_reports."
    },
    "require-dev": {
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\SeoSuite\\": "src/",
            "Capell\\SeoSuite\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\SeoSuite\\Providers\\SeoSuiteServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
