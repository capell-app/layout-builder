{
    "manifest-version": 3,
    "name": "capell-app/newsletter",
    "slug": "newsletter",
    "displayName": "Newsletter",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Newsletter adds subscriber capture and audience workflows for Capell sites.",
    "product": {
        "group": "Capell Marketing",
        "tier": "premium",
        "bundle": "newsletter"
    },
    "namespace": "Capell\\Newsletter",
    "surfaces": ["admin", "frontend"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/form-builder",
            "capell-app/frontend",
            "capell-app/tags"
        ],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": ["Capell\\Newsletter\\Providers\\NewsletterServiceProvider"],
        "admin": ["Capell\\Newsletter\\Providers\\AdminServiceProvider"],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": ["newsletter", "newsletter-admin", "newsletter-frontend"],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": ["newsletter"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "newsletter.form-subscription",
            "label": "Form submissions can create subscribers with consent evidence",
            "class": "Capell\\Newsletter\\Health\\NewsletterHealthCheck",
            "severity": "critical",
            "surface": "frontend"
        },
        {
            "key": "newsletter.provider-sync-retry",
            "label": "Provider sync failures are retried through durable sync attempts",
            "class": "Capell\\Newsletter\\Health\\NewsletterHealthCheck",
            "severity": "critical",
            "surface": "admin"
        },
        {
            "key": "newsletter.provider-webhooks",
            "label": "Provider webhooks normalize remote subscriber state",
            "class": "Capell\\Newsletter\\Health\\NewsletterHealthCheck",
            "severity": "warning",
            "surface": "frontend"
        },
        {
            "key": "newsletter.segments",
            "label": "Static and dynamic subscriber segments evaluate through typed actions",
            "class": "Capell\\Newsletter\\Health\\NewsletterHealthCheck",
            "severity": "warning",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "Newsletter adds subscriber capture and audience workflows for Capell sites.",
        "screenshots": [],
        "categories": ["admin", "frontend", "newsletter"]
    },
    "contributionTraceability": {
        "deferredContributions": [
            "admin-resource",
            "model",
            "overview-stat",
            "route",
            "scheduled-job"
        ]
    }
}
