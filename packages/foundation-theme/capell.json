{
    "manifest-version": 3,
    "name": "capell-app/foundation-theme",
    "slug": "foundation-theme",
    "displayName": "Foundation Theme",
    "kind": "theme",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Foundation Theme provides the default Capell theme assets, Tailwind pipeline, Blade directives, and media handling.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\FoundationTheme",
    "surfaces": ["admin", "frontend"],
    "dependencies": {
        "requires": ["capell-app/frontend"],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\FoundationTheme\\Providers\\FoundationThemeServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": true,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": "capell:foundation-theme-setup",
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": ["foundation-theme"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "foundation-theme.package-health",
            "label": "Foundation Theme package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\FoundationTheme\\Health\\FoundationThemeHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "Foundation Theme provides the default Capell theme assets, Tailwind pipeline, Blade directives, and media handling.",
        "screenshots": [],
        "categories": ["admin", "foundation", "frontend"]
    },
    "extends": null,
    "themeKey": "default",
    "contributionTraceability": {
        "deferredContributions": ["route"]
    }
}
