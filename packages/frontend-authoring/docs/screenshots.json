    "browserTests": [
        {
            "id": "anonymous-users-receive-no-authoring-surface",
            "entry": "frontend-page-with-authoring-enabled",
            "actor": "anonymous",
            "assertions": [
                "no CapellFrontendAuthoring global",
                "no capell-authoring DOM",
                "no edit_url, recordKey, model, field path, selector, label, or signed URL in the response or DOM"
            ]
        },
        {
            "id": "admin-can-open-single-field-editor",
            "entry": "frontend-page-with-authoring-enabled",
            "actor": "admin",
            "assertions": [
                "beacon returns an authoring bootstrap script",
                "page title edit control appears after the beacon runs",
                "clicking the control opens a same-origin signed iframe",
                "iframe renders exactly one Filament field"
            ]
        }
    ],
