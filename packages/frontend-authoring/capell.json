{
    "manifest-version": 3,
    "name": "capell-app/frontend-authoring",
    "slug": "frontend-authoring",
    "displayName": "Frontend Authoring",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Frontend Authoring owns the admin beacon, in-page edit manifest, signed edit routes, and cache-aware field saves.",
    "product": {
        "group": "Capell Foundation",
        "tier": "free",
        "bundle": "foundation"
    },
    "namespace": "Capell\\FrontendAuthoring",
    "surfaces": ["frontend", "console"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/frontend",
            "capell-app/html-cache"
        ],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\FrontendAuthoring\\Providers\\FrontendAuthoringServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 0,
        "cacheTags": ["frontend-authoring"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "frontend-authoring.package-health",
            "label": "Frontend Authoring package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\FrontendAuthoring\\Health\\FrontendAuthoringHealthCheck",
            "severity": "critical",
            "surface": "frontend"
        }
    ],
    "commercial": {
        "proposedLicense": "free",
        "requestedCertification": "first-party",
        "supportPolicy": "capell-first-party",
        "privateDocsRequested": false
    },
    "marketplace": {
        "summary": "Frontend Authoring owns the admin beacon, in-page edit manifest, signed edit routes, and cache-aware field saves.",
        "screenshots": [],
        "categories": ["console", "foundation", "frontend"]
    },
    "scopes": ["frontend"],
    "contributionTraceability": {
        "deferredContributions": ["route"]
    }
}
