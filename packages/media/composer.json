{
    "name": "capell-app/media",
    "description": "Media handling and admin UI for Capell CMS using Spatie MediaLibrary.",
    "keywords": [
        "capell",
        "media",
        "laravel",
        "filamentphp"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/navigation": "*",
        "filament/spatie-laravel-media-library-plugin": "^4.0|^5.0",
        "spatie/laravel-medialibrary": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Media\\": "src/",
            "Capell\\Media\\Database\\Factories\\": "database/factories"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Media\\Providers\\MediaServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
