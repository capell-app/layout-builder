{
    "name": "capell-app/translation-manager",
    "description": "File-based Laravel translation management for Capell and Filament admin panels.",
    "type": "library",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Capell\\TranslationManager\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\TranslationManager\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\TranslationManager\\Providers\\TranslationManagerServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "capell-app/admin": "^4.0",
        "capell-app/core": "^4.0",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-data": "^4.5",
        "spatie/laravel-package-tools": "^1.14.1"
    },
    "suggest": {
        "capell-app/ai-orchestrator": "Enable optional AI translation capabilities."
    }
}
