{
    "manifest-version": 3,
    "name": "capell-app/translation-manager",
    "slug": "translation-manager",
    "displayName": "Translation Manager",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Translation Manager provides a file-based Filament editor for Laravel language files with safe package override writes.",
    "product": {
        "group": "Capell Admin",
        "tier": "premium",
        "bundle": "admin"
    },
    "namespace": "Capell\\TranslationManager",
    "surfaces": ["admin"],
    "dependencies": {
        "requires": ["capell-app/admin", "capell-app/core"],
        "optional": ["capell-app/ai-orchestrator"],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\TranslationManager\\Providers\\TranslationManagerServiceProvider"
        ],
        "admin": [
            "Capell\\TranslationManager\\Providers\\AdminServiceProvider"
        ],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [
        "translation.ai.translate-selected",
        "translation.files.browse",
        "translation.files.duplicate",
        "translation.files.write"
    ],
    "performance": {
        "frontendRenderBudgetMs": 0,
        "adminQueryBudget": 40,
        "cacheTags": [],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": [],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": false
        }
    },
    "healthChecks": [
        {
            "key": "translation-manager.package-health",
            "label": "Translation Manager package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\TranslationManager\\Health\\TranslationManagerHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "Translation Manager provides a file-based Filament editor for Laravel language files with safe package override writes.",
        "screenshots": [],
        "categories": ["admin"]
    },
    "contributionTraceability": {
        "deferredContributions": ["admin-page"]
    }
}
