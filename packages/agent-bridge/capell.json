{
    "manifest-version": 3,
    "name": "capell-app/agent-bridge",
    "slug": "agent-bridge",
    "displayName": "Agent Bridge",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Agent Bridge exposes Capell knowledge and site capabilities through Laravel Agent Bridge servers.",
    "product": {
        "group": "Capell Operations",
        "tier": "premium",
        "bundle": "operations"
    },
    "namespace": "Capell\\AgentBridge",
    "surfaces": ["admin"],
    "dependencies": {
        "requires": ["capell-app/admin", "capell-app/core"],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\AgentBridge\\Providers\\AgentBridgeServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": ["agent-bridge", "agent-bridge-admin"],
    "performance": {
        "frontendRenderBudgetMs": 0,
        "adminQueryBudget": 40,
        "cacheTags": [],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": [],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": false
        }
    },
    "healthChecks": [
        {
            "key": "agent-bridge.package-health",
            "label": "Agent Bridge package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\AgentBridge\\Health\\AgentBridgeHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "Agent Bridge exposes Capell knowledge and site capabilities through Laravel Agent Bridge servers.",
        "screenshots": [],
        "categories": ["admin", "operations"]
    },
    "contributionTraceability": {
        "deferredContributions": [
            "admin-page",
            "agent-capability",
            "migration",
            "route"
        ]
    }
}
