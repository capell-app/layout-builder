{
    "name": "capell-app/media-assistant",
    "description": "Optional AI-assisted media actions for Capell.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/core": "*",
        "filament/filament": "^4.7|^5.2",
        "laravel/framework": "^11.44.2|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.14.1"
    },
    "suggest": {
        "capell-app/assistant": "Bind Capell\\MediaAssistant\\Contracts\\ImageDoctor to an Assistant-backed implementation."
    },
    "autoload": {
        "psr-4": {
            "Capell\\MediaAssistant\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\MediaAssistant\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\MediaAssistant\\Providers\\MediaAssistantServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
