{
    "manifest-version": 3,
    "name": "capell-app/publishing-studio",
    "slug": "publishing-studio",
    "displayName": "Publishing Studio",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "PublishingStudio provides preview, compare, approve, schedule, publish, restore, and rollback workflows for Capell content.",
    "product": {
        "group": "Capell Publishing Pro",
        "tier": "premium",
        "bundle": "publishing-pro"
    },
    "namespace": "Capell\\PublishingStudio",
    "surfaces": ["admin", "console"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/html-cache",
            "capell-app/migration-assistant",
            "capell-app/navigation"
        ],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [
            "Capell\\PublishingStudio\\Providers\\ConsoleServiceProvider"
        ],
        "runtime": [
            "Capell\\PublishingStudio\\Providers\\PublishingStudioServiceProvider"
        ],
        "admin": ["Capell\\PublishingStudio\\Providers\\AdminServiceProvider"],
        "frontend": []
    },
    "contributes": [
        {
            "type": "admin-page",
            "class": "Capell\\PublishingStudio\\Manifest\\PublishingWorkflowPageContribution",
            "pageClass": "Capell\\PublishingStudio\\Filament\\Pages\\PublishingWorkflowPage",
            "labelKey": "capell-publishing-studio::workflow.navigation.label",
            "permission": "View:PublishingWorkflowPage"
        },
        {
            "type": "workflow-attention",
            "class": "Capell\\PublishingStudio\\Actions\\Workflow\\BuildPublishingWorkflowAttentionItemsAction",
            "pageClass": "Capell\\PublishingStudio\\Filament\\Pages\\PublishingWorkflowPage",
            "labelKey": "capell-publishing-studio::workflow.dashboard.label",
            "descriptionKey": "capell-publishing-studio::workflow.dashboard.description",
            "actionLabelKey": "capell-publishing-studio::workflow.dashboard.action",
            "permission": "View:PublishingWorkflowPage"
        }
    ],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": ["workspaces"]
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [
        "submit_workspace_for_approval",
        "approve_workspace",
        "publish_workspace",
        "rollback_workspace",
        "publish_outside_release_window",
        "View:ActivityTrailPage",
        "View:PublishingWorkflowPage",
        "View:ScheduledPublishingPage",
        "View:StaleDraftsPage"
    ],
    "capabilities": [
        "activity-history",
        "approval-history",
        "content-compare",
        "dry-run-validation",
        "editorial-timeline",
        "embargo-windows",
        "entity-restore",
        "field-comments",
        "live-preview",
        "load-testing",
        "preview-link-management",
        "publish-readiness",
        "recovery-imports",
        "release-window-guards",
        "review-assignments",
        "review-reminders",
        "rollback-restore",
        "scheduled-publishing",
        "stale-draft-management",
        "url-collision-checks",
        "version-history",
        "workspace-pruning"
    ],
    "performance": {
        "frontendRenderBudgetMs": 0,
        "adminQueryBudget": 40,
        "cacheTags": [],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": [],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": false
        }
    },
    "healthChecks": [
        {
            "key": "publishing-studio.package-health",
            "label": "Publishing Studio package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\PublishingStudio\\Health\\PublishingStudioHealthCheck",
            "severity": "critical",
            "surface": "admin"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "PublishingStudio provides preview, compare, approve, schedule, publish, restore, and rollback workflows for Capell content.",
        "screenshots": [],
        "categories": ["admin", "console", "publishing-pro"]
    },
    "contributionTraceability": {
        "deferredContributions": [
            "admin-page",
            "admin-resource",
            "dashboard-widget",
            "model",
            "overview-stat",
            "route",
            "scheduled-job"
        ]
    }
}
