{
    "manifest-version": 3,
    "name": "capell-app/site-discovery",
    "slug": "site-discovery",
    "displayName": "Site Discovery",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Site Discovery resolves public discoverable pages and URLs, then exposes HTML and XML sitemap outputs.",
    "product": {
        "group": "Capell Search & SEO",
        "tier": "premium",
        "bundle": "search-seo"
    },
    "namespace": "Capell\\SiteDiscovery",
    "surfaces": ["admin", "frontend", "console"],
    "dependencies": {
        "requires": [
            "capell-app/admin",
            "capell-app/core",
            "capell-app/frontend"
        ],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\SiteDiscovery\\Providers\\SiteDiscoveryServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": [
        "site-discovery",
        "site-discovery-admin",
        "site-discovery-console",
        "site-discovery-frontend"
    ],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 40,
        "cacheTags": ["site-discovery"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "site-discovery.public-urls",
            "label": "Discoverable public URLs are resolved with site and language scope.",
            "class": "Capell\\SiteDiscovery\\Health\\SiteDiscoveryHealthCheck",
            "severity": "critical",
            "surface": "frontend"
        },
        {
            "key": "site-discovery.xml-sitemaps",
            "label": "XML sitemap generation writes domain-scoped sitemap files.",
            "class": "Capell\\SiteDiscovery\\Health\\SiteDiscoveryHealthCheck",
            "severity": "critical",
            "surface": "console"
        },
        {
            "key": "site-discovery.incremental",
            "label": "Incremental sitemap generation skips unchanged URL maps.",
            "class": "Capell\\SiteDiscovery\\Health\\SiteDiscoveryHealthCheck",
            "severity": "warning",
            "surface": "console"
        },
        {
            "key": "site-discovery.html-sitemap",
            "label": "HTML sitemap page renders discoverable page hierarchy.",
            "class": "Capell\\SiteDiscovery\\Health\\SiteDiscoveryHealthCheck",
            "severity": "warning",
            "surface": "frontend"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "Site Discovery resolves public discoverable pages and URLs, then exposes HTML and XML sitemap outputs.",
        "screenshots": [],
        "categories": ["admin", "console", "frontend", "search-seo"]
    },
    "contributionTraceability": {
        "deferredContributions": ["route"]
    }
}
