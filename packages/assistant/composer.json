{
    "name": "capell-app/assistant",
    "description": "Capell Assistant orchestration package",
    "keywords": [
        "capell",
        "assistant",
        "ai"
    ],
    "homepage": "https://capell.app",
    "license": "proprietary",
    "authors": [
        {
            "name": "Howdu",
            "email": "cms.multi2@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "capell-app/admin": "*",
        "capell-app/core": "*",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-data": "^4.5",
        "spatie/laravel-package-tools": "^1.14.1"
    },
    "autoload": {
        "psr-4": {
            "Capell\\Assistant\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\Assistant\\Providers\\AssistantServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true
}
