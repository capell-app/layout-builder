{
    "name": "capell-app/theme-studio-core",
    "description": "Core contracts, registry, preview context, and rendering support for Capell Theme Studio",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "capell-app/core": "*",
        "capell-app/frontend": "*",
        "lorisleiva/laravel-actions": "^2.8",
        "spatie/laravel-data": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^3.0|^4.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Capell\\ThemeStudio\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Capell\\ThemeStudio\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Capell\\ThemeStudio\\Core\\ThemeStudioCoreServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "4.x-dev"
        }
    }
}
