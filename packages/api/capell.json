{
    "manifest-version": 3,
    "name": "capell-app/api",
    "slug": "api",
    "displayName": "API",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Public JSON delivery of published Capell page data.",
    "product": {
        "group": "Capell Publishing Pro",
        "tier": "premium",
        "bundle": "publishing-pro"
    },
    "namespace": "Capell\\Api",
    "surfaces": ["frontend"],
    "dependencies": {
        "requires": ["capell-app/core"],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": ["Capell\\Api\\Providers\\ApiServiceProvider"],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": false,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": ["public-page-api", "public-page-api-v1"],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 0,
        "cacheTags": ["api", "api:pages"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "api.v1.route",
            "label": "V1 page resolve route is registered",
            "class": "Capell\\Api\\Health\\ApiHealthCheck",
            "severity": "critical",
            "surface": "frontend"
        },
        {
            "key": "api.middleware.config",
            "label": "Host middleware configuration is publishable",
            "class": "Capell\\Api\\Health\\ApiHealthCheck",
            "severity": "warning",
            "surface": "frontend"
        },
        {
            "key": "api.cache.headers",
            "label": "API responses expose version and cache-tag headers",
            "class": "Capell\\Api\\Health\\ApiHealthCheck",
            "severity": "warning",
            "surface": "frontend"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "Public JSON delivery of published Capell page data.",
        "screenshots": [],
        "categories": ["frontend", "publishing-pro"]
    },
    "contributionTraceability": {
        "deferredContributions": ["route", "public-api-endpoint"]
    }
}
