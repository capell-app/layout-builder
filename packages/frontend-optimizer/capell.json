{
    "manifest-version": 3,
    "name": "capell-app/frontend-optimizer",
    "slug": "frontend-optimizer",
    "displayName": "Frontend Optimizer",
    "kind": "package",
    "capellApiVersion": "^4.0",
    "version": "4.x-dev",
    "description": "Frontend Optimizer provides profile-based CSS and JavaScript delivery for public Capell pages.",
    "product": {
        "group": "Capell Foundation",
        "tier": "premium",
        "bundle": "foundation"
    },
    "namespace": "Capell\\FrontendOptimizer",
    "surfaces": ["frontend"],
    "dependencies": {
        "requires": ["capell-app/core", "capell-app/frontend"],
        "optional": [],
        "conflicts": []
    },
    "providers": {
        "metadata": [],
        "install": [],
        "runtime": [
            "Capell\\FrontendOptimizer\\Providers\\FrontendOptimizerServiceProvider"
        ],
        "admin": [],
        "frontend": []
    },
    "contributes": [],
    "database": {
        "migrations": true,
        "settings": false,
        "requiredTables": []
    },
    "commands": {
        "install": null,
        "setup": null,
        "demo": null,
        "doctor": null
    },
    "settings": [],
    "permissions": [],
    "capabilities": ["frontend-optimizer", "frontend-optimizer-frontend"],
    "performance": {
        "frontendRenderBudgetMs": 20,
        "adminQueryBudget": 0,
        "cacheTags": ["frontend-optimizer"],
        "cacheSafety": {
            "cacheable": false,
            "variesBy": ["site", "locale"],
            "sensitiveOutput": false,
            "invalidationSources": [],
            "queueInvalidation": true
        }
    },
    "healthChecks": [
        {
            "key": "frontend-optimizer.package-health",
            "label": "Frontend Optimizer package surfaces, providers, and install health are discoverable by Diagnostics.",
            "class": "Capell\\FrontendOptimizer\\Health\\FrontendOptimizerHealthCheck",
            "severity": "critical",
            "surface": "frontend"
        }
    ],
    "commercial": {
        "proposedLicense": "paid",
        "requestedCertification": "first-party",
        "supportPolicy": "priority",
        "privateDocsRequested": true
    },
    "marketplace": {
        "summary": "Frontend Optimizer provides profile-based CSS and JavaScript delivery for public Capell pages.",
        "screenshots": [],
        "categories": ["foundation", "frontend"]
    },
    "scopes": ["frontend"]
